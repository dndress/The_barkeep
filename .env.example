# --- Webhook auth (must match values set in Chronicler) ---
# Shared secret Chronicler sends in the X-Webhook-Secret header.
BARKEEP_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Server ---
# Port Fastify listens on. Inside Docker this stays 3001; Chronicler reaches
# it as http://barkeep:3001/api/recordings/complete on the shared network.
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Postgres 17 + pgvector) ---
# Used in later stages; declared now so .env stays the single source of truth.
DATABASE_URL=postgresql://barkeep:barkeep@db:5432/barkeep?schema=public

# --- Paths into the shared Chronicler volume (read-only mount) ---
# When Chronicler POSTs filenames they will be under /app/rec/* — Barkeep sees
# the same paths because both containers mount the craig_rec volume there.
CHRONICLER_REC_PATH=/app/rec

# --- Gemini (added in later stages, declared here for reference) ---
# GEMINI_API_KEY=
# GEMINI_API_KEY_PAID=
