# --- Webhook auth (must match values set in Chronicler) ---
# Shared secret Chronicler sends in the X-Webhook-Secret header.
BARKEEP_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Server ---
# Port Fastify listens on. Inside Docker this stays 3001; Chronicler reaches
# it as http://barkeep:3001/api/recordings/complete on the shared network.
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Postgres 17 + pgvector) ---
# Used in later stages; declared now so .env stays the single source of truth.
# Hostname is `barkeep-db`, NOT `db` — both stacks share Chronicler's network,
# and Chronicler also has a `db` service. The Barkeep service name had to be
# unique to avoid Docker DNS round-robin between the two postgres containers.
DATABASE_URL=postgresql://barkeep:barkeep@barkeep-db:5432/barkeep?schema=public&connection_limit=20&pool_timeout=30

# --- Paths into the shared Chronicler volume (read-only mount) ---
# When Chronicler POSTs filenames they will be under /app/rec/* — Barkeep sees
# the same paths because both containers mount the craig_rec volume there.
CHRONICLER_REC_PATH=/app/rec

# --- Cooked output (Barkeep-managed volume) ---
# Per-track FLAC files land under <COOKED_PATH>/<sessionId>/<chapterIndex>/.
COOKED_PATH=/app/data/cooked

# --- Pipeline worker tuning ---
# How often the worker polls for unprocessed chapters.
WORKER_POLL_INTERVAL_MS=30000
# Hard timeout for a single cook invocation. Cook on a long chapter should
# finish in a few minutes; 30m is generous.
COOK_TIMEOUT_MS=1800000

# --- Gemini (required for Stage 4 transcription) ---
# Paste the paid-tier API key from the player whose Gemini subscription we're
# using. Free tier works at low volume; paid keeps weekly 4-hr sessions
# within the $10/mo budget without hitting RPM/RPD limits.
GEMINI_API_KEY=

# Transcription tuning. Defaults are tested for 4-5 hr sessions with 6-8
# tracks per chapter at Spanish-primary content.
TRANSCRIBE_MODEL=gemini-2.5-flash
TRANSCRIBE_LANGUAGE_HINT=es
# Concurrent AudioFile transcriptions per worker tick. 2 is gentle on both
# the VPS and the Gemini rate limits; bump if your tracks transcribe slow.
TRANSCRIBE_CONCURRENCY=2
# Hard cap on retries per AudioFile. After this many failures the file is
# parked with the error stored in transcribe_error; operator nulls
# transcribe_attempts to retry manually.
TRANSCRIBE_MAX_ATTEMPTS=3
# Hard timeout for a single transcribe (upload + wait + generate + delete).
TRANSCRIBE_TIMEOUT_MS=1200000
